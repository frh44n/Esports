# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# SUPABASE_URL: The URL of your Supabase project.
SUPABASE_URL=https://your-project.supabase.co

# SUPABASE_ANON_KEY: The public anonymous API key for your Supabase project.
SUPABASE_ANON_KEY=your-supabase-anon-key

# SUPABASE_PUBLISHABLE_KEY: The public publishable key.
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# SUPABASE_SECRET_KEY: The secret service role key.
SUPABASE_SECRET_KEY=your-supabase-secret-key

# SUPABASE_JWKS_URL: JWKS URL for token validation.
SUPABASE_JWKS_URL=your-supabase-jwks-url

# SERVER_URL: The URL of your hosted backend server (e.g. on Render).
SERVER_URL=https://esports-13p1.onrender.com


